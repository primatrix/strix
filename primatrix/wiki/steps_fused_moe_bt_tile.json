    "compute_unit": "MXU",
    "fusable_with_prev": false,
    "_comment": "64 experts × [64,8192]×[8192,2048], aggregated. M=64×64=4096, N=64×2048=131072 for total data volume. FLOPs = 64 × 2×64×8192×2048 = 137,438,953,472"
  },
  {
    "name": "expert_ffn1_up_all64",
    "op_type": "matmul",
    "inputs": [
      {"name": "tokens_scattered", "shape": [4096, 8192], "dtype": "bf16"},
      {"name": "W3_all_experts", "shape": [8192, 131072], "dtype": "bf16"}
    ],
    "outputs": [{"name": "up_all", "shape": [4096, 131072], "dtype": "bf16"}],
    "flops_formula": "2*M*N*K",
    "flops_vars": {"M": 4096, "N": 131072, "K": 8192},
    "compute_unit": "MXU",
    "fusable_with_prev": false,
    "_comment": "64 experts × [64,8192]×[8192,2048] aggregated"
  },
  {
    "name": "silu_gated_activation_all64",
